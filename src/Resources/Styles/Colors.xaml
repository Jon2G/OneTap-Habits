<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand palette: charcoal minimal + green accent on completion -->
    <Color x:Key="Background">#FAFAFA</Color>
    <Color x:Key="BackgroundDark">#121212</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#1E1E1E</Color>
    <Color x:Key="SurfaceVariant">#F0F0F0</Color>
    <Color x:Key="SurfaceVariantDark">#2A2A2A</Color>
    <Color x:Key="OnBackground">#1A1A1A</Color>
    <Color x:Key="OnBackgroundDark">#F5F5F5</Color>
    <Color x:Key="OnSurfaceMuted">#6B7280</Color>
    <Color x:Key="OnSurfaceMutedDark">#9CA3AF</Color>
    <Color x:Key="Outline">#E5E7EB</Color>
    <Color x:Key="OutlineDark">#374151</Color>
    <Color x:Key="Primary">#1A1A1A</Color>
    <Color x:Key="PrimaryDark">#F5F5F5</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>
    <Color x:Key="OnPrimaryDark">#121212</Color>
    <Color x:Key="AccentComplete">#22C55E</Color>
    <Color x:Key="AccentCompleteDark">#4ADE80</Color>
    <Color x:Key="Error">#DC2626</Color>
    <Color x:Key="ErrorDark">#F87171</Color>

    <!-- Legacy aliases for Styles.xaml -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#030712</Color>
    <Color x:Key="Secondary">#F0F0F0</Color>
    <Color x:Key="SecondaryDarkText">#9CA3AF</Color>
    <Color x:Key="PrimaryDarkText">#F5F5F5</Color>
    <Color x:Key="Tertiary">#22C55E</Color>

    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
    <SolidColorBrush x:Key="OnBackgroundBrush" Color="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{AppThemeBinding Light={StaticResource OnSurfaceMuted}, Dark={StaticResource OnSurfaceMutedDark}}" />
    <SolidColorBrush x:Key="OutlineBrush" Color="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}" />
    <SolidColorBrush x:Key="AccentCompleteBrush" Color="{AppThemeBinding Light={StaticResource AccentComplete}, Dark={StaticResource AccentCompleteDark}}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}" />
</ResourceDictionary>
