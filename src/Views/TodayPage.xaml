<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OneTapHabits.ViewModels"
             x:Class="OneTapHabits.Views.TodayPage"
             x:DataType="vm:TodayViewModel"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding OpenSettingsCommand}"
                     Order="Primary"
                     Priority="0"
                     SemanticProperties.Description="{Binding SettingsLabel}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xE8B8;"
                                 Size="24"
                                 Color="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="12">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
            <Button Grid.Column="0"
                    Text="&#xE314;"
                    FontFamily="MaterialIcons"
                    FontSize="22"
                    Command="{Binding PreviousDayCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}"
                    Padding="8"
                    SemanticProperties.Description="{Binding PreviousDayLabel}" />
            <Label Grid.Column="1"
                   Text="{Binding Title}"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
            <Button Grid.Column="2"
                    Text="&#xE315;"
                    FontFamily="MaterialIcons"
                    FontSize="22"
                    Command="{Binding NextDayCommand}"
                    IsEnabled="{Binding CanGoToNextDay}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}"
                    Padding="8"
                    SemanticProperties.Description="{Binding NextDayLabel}" />
        </Grid>

        <Button Grid.Row="1"
                Text="{Binding GoToTodayLabel}"
                Command="{Binding GoToTodayCommand}"
                IsVisible="{Binding ShowGoToToday}"
                HorizontalOptions="Center"
                BackgroundColor="Transparent"
                TextColor="{AppThemeBinding Light={StaticResource AccentComplete}, Dark={StaticResource AccentCompleteDark}}" />

        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView x:Name="HabitsCollectionView"
                            ItemsSource="{Binding Habits}"
                            SelectionMode="None"
                            CanReorderItems="{Binding IsViewingToday}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TodayHabitItem">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItemView>
                                        <Grid WidthRequest="48"
                                              BackgroundColor="{AppThemeBinding Light={StaticResource AccentComplete}, Dark={StaticResource AccentCompleteDark}}"
                                              SemanticProperties.Description="{Binding EditLabel}">
                                            <Label Text="&#xE3C9;"
                                                   FontFamily="MaterialIcons"
                                                   FontSize="20"
                                                   TextColor="{StaticResource OnPrimary}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding EditCommand}"
                                                                      CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                        </Grid>
                                    </SwipeItemView>
                                    <SwipeItemView>
                                        <Grid WidthRequest="48"
                                              BackgroundColor="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                                              SemanticProperties.Description="{Binding DeleteLabel}">
                                            <Label Text="&#xE872;"
                                                   FontFamily="MaterialIcons"
                                                   FontSize="20"
                                                   TextColor="{StaticResource OnPrimary}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding DeleteCommand}"
                                                                      CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                        </Grid>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Margin="0,0,0,12" Padding="16"
                                    Stroke="{Binding CompletedStrokeColor}"
                                    BackgroundColor="{Binding CardBackgroundColor}"
                                    SemanticProperties.Hint="{Binding SwipeHint}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding IncrementCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                                    <BoxView Grid.Column="0" Color="{Binding AccentColor}" CornerRadius="2" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding Habit.Name}" FontSize="18" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
                                        <Label Text="{Binding StreakLabel}" FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMuted}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                        <Label Text="{Binding CompletedLabel}" FontSize="13"
                                               TextColor="{Binding CompletedTextColor}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="3"
                Command="{Binding AddHabitCommand}"
                CornerRadius="28"
                HeightRequest="56"
                WidthRequest="56"
                Padding="0"
                HorizontalOptions="End"
                Margin="0,12,0,0"
                SemanticProperties.Description="{Binding AddHabitLabel}">
            <Button.ImageSource>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xE145;"
                                 Size="28"
                                 Color="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}" />
            </Button.ImageSource>
        </Button>
    </Grid>
</ContentPage>
