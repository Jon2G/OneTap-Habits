<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OneTapHabits.ViewModels"
             x:Class="OneTapHabits.Views.TodayPage"
             x:DataType="vm:TodayViewModel"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding OpenSettingsCommand}"
                     Order="Primary"
                     Priority="0"
                     SemanticProperties.Description="{Binding SettingsLabel}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xE8B8;"
                                 Size="24"
                                 Color="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto" Padding="16">
        <RefreshView Grid.Row="0" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Habits}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TodayHabitItem">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="{Binding EditLabel}"
                                               BackgroundColor="{AppThemeBinding Light={StaticResource AccentComplete}, Dark={StaticResource AccentCompleteDark}}"
                                               Command="{Binding EditCommand}"
                                               CommandParameter="{Binding .}" />
                                    <SwipeItem Text="{Binding DeleteLabel}"
                                               BackgroundColor="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}"
                                               Command="{Binding DeleteCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Margin="0,0,0,12" Padding="16"
                                    Stroke="{Binding CompletedStrokeColor}"
                                    BackgroundColor="{Binding CardBackgroundColor}"
                                    SemanticProperties.Hint="{Binding SwipeHint}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                                    <BoxView Grid.Column="0" Color="{Binding AccentColor}" CornerRadius="2" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding Habit.Name}" FontSize="18" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}" />
                                        <Label Text="{Binding StreakLabel}" FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMuted}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                        <Label Text="{Binding CompletedLabel}" FontSize="13"
                                               TextColor="{Binding CompletedTextColor}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="1"
                Command="{Binding AddHabitCommand}"
                CornerRadius="28"
                HeightRequest="56"
                WidthRequest="56"
                Padding="0"
                HorizontalOptions="End"
                Margin="0,12,0,0"
                SemanticProperties.Description="{Binding AddHabitLabel}">
            <Button.ImageSource>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xE145;"
                                 Size="28"
                                 Color="{AppThemeBinding Light={StaticResource OnPrimary}, Dark={StaticResource OnPrimaryDark}}" />
            </Button.ImageSource>
        </Button>
    </Grid>
</ContentPage>
