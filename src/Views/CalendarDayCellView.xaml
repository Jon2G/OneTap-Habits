<?xml version="1.0" encoding="utf-8" ?>
<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:vm="clr-namespace:OneTapHabits.ViewModels"
        xmlns:views="clr-namespace:OneTapHabits.Views"
        x:Class="OneTapHabits.Views.CalendarDayCellView"
        x:DataType="vm:CalendarDayDisplay"
        Padding="0"
        StrokeThickness="1"
        Stroke="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}">
    <Border.Triggers>
        <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource AccentComplete}, Dark={StaticResource AccentCompleteDark}}" />
        </DataTrigger>
    </Border.Triggers>
    <Border.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type views:CalendarPage}}, Path=BindingContext.OpenDayCommand}"
                              CommandParameter="{Binding .}" />
    </Border.GestureRecognizers>
    <Grid>
        <FlexLayout Direction="Column"
                    IsVisible="{Binding HasLines}"
                    BindableLayout.ItemsSource="{Binding Lines}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:CalendarLineDisplay">
                    <BoxView Color="{Binding LineColor}" FlexLayout.Grow="1" />
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>
        <Label Text="{Binding DayNumber}"
               FontSize="18"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource OnBackgroundDark}}">
            <Label.Triggers>
                <DataTrigger TargetType="Label" Binding="{Binding HasLines}" Value="True">
                    <Setter Property="TextColor" Value="White" />
                    <Setter Property="Shadow">
                        <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.55" />
                    </Setter>
                </DataTrigger>
                <DataTrigger TargetType="Label" Binding="{Binding IsCurrentMonth}" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </DataTrigger>
            </Label.Triggers>
        </Label>
    </Grid>
</Border>
